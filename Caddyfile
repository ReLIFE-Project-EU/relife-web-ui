:8080 {
	# Enable gzip compression
	encode gzip

	# Security headers
	header {
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
	}

	# Public Umami tracking endpoints. The dashboard is not exposed through Caddy.
	handle /umami/script.js {
		rewrite * /script.js
		reverse_proxy {$UMAMI_URL:http://umami:3000}
	}

	handle /api/send {
		reverse_proxy {$UMAMI_URL:http://umami:3000}
	}

	handle /umami/api/send {
		rewrite * /api/send
		reverse_proxy {$UMAMI_URL:http://umami:3000}
	}

	# API reverse proxy
	handle_path /api/technical/* {
		reverse_proxy {$API_TECHNICAL_URL:http://technical:9090}
	}

	handle_path /api/financial/* {
		reverse_proxy {$API_FINANCIAL_URL:http://financial:9090}
	}

	handle_path /api/forecasting/* {
		reverse_proxy {$API_FORECASTING_URL:http://forecasting:9090}
	}

	# FastAPI's Swagger UI in the backend images still requests root-level assets.
	# Route those requests back to the originating service based on the docs page referer.
	@financialDocsOpenAPI {
		path /openapi.json
		header_regexp Referer ^https?://[^/]+/api/financial/docs(?:[/?#].*)?$
	}
	handle @financialDocsOpenAPI {
		reverse_proxy {$API_FINANCIAL_URL:http://financial:9090}
	}

	@forecastingDocsOpenAPI {
		path /openapi.json
		header_regexp Referer ^https?://[^/]+/api/forecasting/docs(?:[/?#].*)?$
	}
	handle @forecastingDocsOpenAPI {
		reverse_proxy {$API_FORECASTING_URL:http://forecasting:9090}
	}

	@technicalDocsOpenAPI {
		path /openapi.json
		header_regexp Referer ^https?://[^/]+/api/technical/docs(?:[/?#].*)?$
	}
	handle @technicalDocsOpenAPI {
		reverse_proxy {$API_TECHNICAL_URL:http://technical:9090}
	}

	@financialDocsOAuthRedirect {
		path /docs/oauth2-redirect
		header_regexp Referer ^https?://[^/]+/api/financial/docs(?:[/?#].*)?$
	}
	handle @financialDocsOAuthRedirect {
		reverse_proxy {$API_FINANCIAL_URL:http://financial:9090}
	}

	@forecastingDocsOAuthRedirect {
		path /docs/oauth2-redirect
		header_regexp Referer ^https?://[^/]+/api/forecasting/docs(?:[/?#].*)?$
	}
	handle @forecastingDocsOAuthRedirect {
		reverse_proxy {$API_FORECASTING_URL:http://forecasting:9090}
	}

	@technicalDocsOAuthRedirect {
		path /docs/oauth2-redirect
		header_regexp Referer ^https?://[^/]+/api/technical/docs(?:[/?#].*)?$
	}
	handle @technicalDocsOAuthRedirect {
		reverse_proxy {$API_TECHNICAL_URL:http://technical:9090}
	}

	# Single-page application fallback
	# Serve index.html for all non-API routes
	handle {
		root * /srv/dist
		try_files {path} /index.html
		file_server
	}
}
